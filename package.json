{
  "name": "woocommerce-gateway-payline",
  "title": "WooCommerce Payline Payments",
  "version": "1.5.0",
  "author": "Payline",
  "license": "GPL-3.0+",
  "keywords": [],
  "engines": {
    "node": ">=20.11.1",
    "npm": ">=8.12.1"
  },
  "devDependencies": {
    "@woocommerce/dependency-extraction-webpack-plugin": "^3.0.0",
    "@woocommerce/eslint-plugin": "^2.2.0",
    "@wordpress/scripts": "^27.7.0",
    "archiver": "^7.0.1",
    "colors": "^1.4.0",
    "shelljs": "^0.8.5"
  },
  "scripts": {
    "build": "composer install --no-dev && npm run build:webpack && npm run archive",
    "start:webpack": "wp-scripts start",
    "build:webpack": "wp-scripts build",
    "archive": "composer archive --file=$npm_package_name --format=zip",
    "postarchive": "rm -rf payline && unzip $npm_package_name.zip -d payline && rm $npm_package_name.zip && zip -r $npm_package_name.zip payline && rm -rf payline",
    "release:gitlab": "node tasks/release.js && mv release/*.zip ."
  }
}
